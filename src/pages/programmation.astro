---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getConcerts, getImageUrl } from '../../backend/backend.mjs';

// Récupérer tous les concerts avec artistes et scènes
const concerts = await getConcerts();

// Grouper les concerts par date
const concertsByDate = concerts.reduce((acc, concert) => {
  const date = concert.date;
  if (!acc[date]) {
    acc[date] = [];
  }
  acc[date].push(concert);
  return acc;
}, {} as Record<string, typeof concerts>);

// Trier les dates
const sortedDates = Object.keys(concertsByDate).sort();

// Formater la date en français
function formatDate(dateString: string): string {
  const date = new Date(dateString);
  return date.toLocaleDateString('fr-FR', {
    weekday: 'long',
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
}

// Données statiques de fallback si pas de concerts dans la BDD
const fallbackDays = [
  {
    date: "2026-08-28",
    concerts: [
      {
        time: "18h00",
        title: "Concert jeune public",
        artist: "Ensemble Matheus",
        location: "Cour d'honneur",
        program: "Pierre et le Loup - Prokofiev",
        price: "15€",
        image: "https://images.unsplash.com/photo-1493225457124-a3eb161ffa5f?auto=format&fit=crop&w=600&q=80"
      },
      {
        time: "20h30",
        title: "Concert d'ouverture",
        artist: "Orchestre National de Lyon",
        conductor: "Dir. Alexandre Bloch",
        location: "Grande scène",
        program: "Beethoven - Symphonie n°9",
        price: "45€ - 85€",
        image: "https://images.unsplash.com/photo-1465847899084-d164df4dedc6?auto=format&fit=crop&w=600&q=80"
      }
    ]
  }
];

const hasDynamicConcerts = sortedDates.length > 0;
---

<Layout title="Programmation - Chorus Symphonia">
  <Header />
  <main class="pt-20">
    <!-- Hero -->
    <section class="py-16 md:py-24 bg-gradient-to-b from-zinc-900 to-zinc-950">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="inline-block text-purple-400 font-medium uppercase tracking-wider text-sm mb-4">28-31 Août 2026</span>
        <h1 class="font-serif text-4xl sm:text-5xl md:text-6xl font-bold text-zinc-100 mb-6">
          Programmation
        </h1>
        <p class="text-zinc-400 max-w-2xl mx-auto text-lg">
          Quatre jours de musique exceptionnelle avec les plus grands artistes de la scène classique internationale.
        </p>
        
        <!-- Quick Links to Artists and Scenes -->
        <div class="flex flex-wrap justify-center gap-4 mt-8">
          <a 
            href="/artistes" 
            class="inline-flex items-center gap-2 px-6 py-3 bg-zinc-800 text-white rounded-full hover:bg-zinc-700 transition-colors"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Découvrir les artistes
          </a>
          <a 
            href="/scenes" 
            class="inline-flex items-center gap-2 px-6 py-3 bg-zinc-800 text-white rounded-full hover:bg-zinc-700 transition-colors"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
            Explorer les scènes
          </a>
        </div>
      </div>
    </section>

    <!-- Program by Day - Dynamic -->
    {hasDynamicConcerts ? (
      <section class="py-16 bg-zinc-950">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          {sortedDates.map((date, dayIndex) => {
            const dayConcerts = concertsByDate[date];
            return (
              <div class="mb-16 last:mb-0">
                <!-- Day Header -->
                <div class="flex items-center gap-4 mb-8">
                  <div class="w-12 h-12 rounded-full bg-purple-600 flex items-center justify-center text-zinc-950 font-bold">
                    {dayIndex + 1}
                  </div>
                  <h2 class="font-serif text-2xl sm:text-3xl font-bold text-zinc-100 capitalize">{formatDate(date)}</h2>
                </div>

                <!-- Concerts -->
                <div class="space-y-6">
                  {dayConcerts.map((concert) => {
                    const artistePhoto = concert.expand?.artiste?.photo 
                      ? getImageUrl(concert.expand.artiste, concert.expand.artiste.photo) 
                      : null;
                    
                    return (
                      <article class="bg-zinc-900/50 rounded-2xl overflow-hidden border border-zinc-800/50 hover:border-purple-500/30 transition-all group">
                        <div class="flex flex-col md:flex-row">
                          <!-- Image -->
                          <div class="md:w-64 lg:w-80 shrink-0">
                            <div class="aspect-[16/10] md:aspect-auto md:h-full">
                              {artistePhoto ? (
                                <img 
                                  src={artistePhoto} 
                                  alt={concert.expand?.artiste?.nom || concert.titre}
                                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                />
                              ) : (
                                <div class="w-full h-full bg-zinc-800 flex items-center justify-center min-h-[200px]">
                                  <svg class="w-16 h-16 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
                                  </svg>
                                </div>
                              )}
                            </div>
                          </div>
                          
                          <!-- Content -->
                          <div class="flex-1 p-6 md:p-8 flex flex-col">
                            <div class="flex flex-wrap items-center gap-3 mb-4">
                              <span class="inline-flex items-center gap-1.5 bg-purple-600/20 text-purple-400 px-3 py-1 rounded-full text-sm font-medium">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                                {concert.heure}
                              </span>
                              {concert.expand?.scene && (
                                <a 
                                  href={`/scenes/${concert.expand.scene.id}`}
                                  class="text-zinc-500 text-sm flex items-center gap-1.5 hover:text-purple-400 transition-colors"
                                >
                                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                                  </svg>
                                  {concert.expand.scene.nom}
                                </a>
                              )}
                            </div>

                            <h3 class="font-serif text-xl sm:text-2xl font-semibold text-zinc-100 mb-2 group-hover:text-purple-400 transition-colors">
                              {concert.titre}
                            </h3>
                            
                            {concert.expand?.artiste && (
                              <a 
                                href={`/artistes/${concert.expand.artiste.id}`}
                                class="text-zinc-300 font-medium mb-1 hover:text-purple-400 transition-colors"
                              >
                                {concert.expand.artiste.nom}
                                {concert.expand.artiste.instrument && (
                                  <span class="text-zinc-500 text-sm ml-2">({concert.expand.artiste.instrument})</span>
                                )}
                              </a>
                            )}
                            
                            {concert.description && (
                              <p class="text-zinc-400 text-sm italic mb-4">{concert.description}</p>
                            )}

                            <div class="mt-auto flex flex-wrap items-center justify-between gap-4 pt-4 border-t border-zinc-800">
                              <div class="text-zinc-400 text-sm">
                                {concert.expand?.scene?.capacite && `${concert.expand.scene.capacite} places`}
                              </div>
                              <a 
                                href="/billetterie" 
                                class="inline-flex items-center gap-2 bg-purple-600 hover:bg-purple-500 text-zinc-950 font-medium px-5 py-2.5 rounded-full transition-all hover:scale-105 text-sm"
                              >
                                Réserver
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                                </svg>
                              </a>
                            </div>
                          </div>
                        </div>
                      </article>
                    );
                  })}
                </div>
              </div>
            );
          })}
        </div>
      </section>
    ) : (
      <!-- Fallback: No concerts in database -->
      <section class="py-16 bg-zinc-950">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center py-12 bg-zinc-900/50 rounded-2xl border border-zinc-800">
            <svg class="w-16 h-16 text-zinc-600 mx-auto mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
            </svg>
            <h3 class="font-serif text-2xl font-bold text-white mb-4">Programmation à venir</h3>
            <p class="text-zinc-400 max-w-md mx-auto mb-8">
              La programmation complète sera bientôt disponible. En attendant, découvrez nos artistes et nos scènes.
            </p>
            <div class="flex flex-wrap justify-center gap-4">
              <a 
                href="/artistes" 
                class="inline-flex items-center gap-2 px-6 py-3 bg-purple-600 text-zinc-950 rounded-full font-medium hover:bg-purple-500/90 transition-colors"
              >
                Voir les artistes
              </a>
              <a 
                href="/scenes" 
                class="inline-flex items-center gap-2 px-6 py-3 bg-zinc-800 text-white rounded-full font-medium hover:bg-zinc-700 transition-colors"
              >
                Voir les scènes
              </a>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="py-16 bg-zinc-900">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="font-serif text-3xl font-bold text-zinc-100 mb-4">Prêt à vivre l'expérience ?</h2>
        <p class="text-zinc-400 mb-8">Réservez dès maintenant vos places pour ne rien manquer de cette édition exceptionnelle.</p>
        <a 
          href="/billetterie" 
          class="inline-flex items-center gap-2 bg-purple-600 hover:bg-purple-500 text-zinc-950 font-semibold px-8 py-4 rounded-full transition-all hover:scale-105"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
          </svg>
          Accéder à la billetterie
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
