---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import {
    getArtiste,
    getConcerts,
    getImageUrl,
} from "../../../backend/backend.mjs";

const { id } = Astro.params;

if (!id) {
    return Astro.redirect("/artistes");
}

const artiste = await getArtiste(id);

if (!artiste) {
    return Astro.redirect("/artistes");
}

const imageUrl = artiste.photo ? getImageUrl(artiste, artiste.photo) : null;

// Récupérer les concerts de cet artiste
const allConcerts = await getConcerts();
const artisteConcerts = allConcerts.filter((c) => c.artiste === artiste.id);
---

<Layout
    title={`${artiste.nom} - Chorus Symphonia`}
    description={artiste.bio ||
        `Découvrez ${artiste.nom} au festival Chorus Symphonia 2026`}
>
    <Header />

    <main class="pt-24">
        <!-- Breadcrumb -->
        <div class="bg-stone-900 py-4">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <nav class="flex items-center gap-2 text-sm">
                    <a
                        href="/"
                        class="text-stone-400 hover:text-primary transition-colors"
                        >Accueil</a
                    >
                    <span class="text-stone-600">/</span>
                    <a
                        href="/artistes"
                        class="text-stone-400 hover:text-primary transition-colors"
                        >Artistes</a
                    >
                    <span class="text-stone-600">/</span>
                    <span class="text-primary">{artiste.nom}</span>
                </nav>
            </div>
        </div>

        <!-- Artiste Detail -->
        <section class="py-16 bg-stone-950">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
                    <!-- Image -->
                    <div class="relative">
                        <div
                            class="aspect-[3/4] rounded-2xl overflow-hidden bg-stone-900"
                        >
                            {
                                imageUrl ? (
                                    <img
                                        src={imageUrl}
                                        alt={artiste.nom}
                                        class="w-full h-full object-cover"
                                    />
                                ) : (
                                    <div class="w-full h-full flex items-center justify-center">
                                        <svg
                                            class="w-32 h-32 text-stone-700"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="1.5"
                                                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                                            />
                                        </svg>
                                    </div>
                                )
                            }
                        </div>
                        <div
                            class="absolute -bottom-4 -right-4 w-24 h-24 bg-primary/20 rounded-full blur-2xl"
                        >
                        </div>
                    </div>

                    <!-- Info -->
                    <div>
                        <h1
                            class="font-serif text-4xl md:text-5xl font-bold text-white mb-4"
                        >
                            {artiste.nom}
                        </h1>

                        {
                            artiste.instrument && (
                                <p class="text-primary text-xl font-medium mb-8">
                                    {artiste.instrument}
                                </p>
                            )
                        }

                        {
                            artiste.bio && (
                                <div class="prose prose-invert prose-stone max-w-none">
                                    <p class="text-stone-300 text-lg leading-relaxed whitespace-pre-line">
                                        {artiste.bio}
                                    </p>
                                </div>
                            )
                        }

                        <!-- Concerts de l'artiste -->
                        {
                            artisteConcerts.length > 0 && (
                                <div class="mt-12">
                                    <h2 class="font-serif text-2xl font-bold text-white mb-6">
                                        Concerts au festival
                                    </h2>
                                    <div class="space-y-4">
                                        {artisteConcerts.map((concert) => {
                                            const date = new Date(concert.date);
                                            const formattedDate =
                                                date.toLocaleDateString(
                                                    "fr-FR",
                                                    {
                                                        weekday: "long",
                                                        day: "numeric",
                                                        month: "long",
                                                    },
                                                );
                                            return (
                                                <div class="bg-stone-900 rounded-xl p-6 border border-stone-800">
                                                    <div class="flex items-start justify-between gap-4">
                                                        <div>
                                                            <h3 class="font-serif text-xl font-bold text-white mb-2">
                                                                {concert.titre}
                                                            </h3>
                                                            <p class="text-stone-400">
                                                                {formattedDate}{" "}
                                                                à{" "}
                                                                {concert.heure}
                                                            </p>
                                                            {concert.expand
                                                                ?.scene && (
                                                                <p class="text-primary mt-1">
                                                                    {
                                                                        concert
                                                                            .expand
                                                                            .scene
                                                                            .nom
                                                                    }
                                                                </p>
                                                            )}
                                                        </div>
                                                        <a
                                                            href="/billetterie"
                                                            class="px-4 py-2 bg-primary text-stone-950 rounded-lg font-medium hover:bg-primary/90 transition-colors whitespace-nowrap"
                                                        >
                                                            Réserver
                                                        </a>
                                                    </div>
                                                </div>
                                            );
                                        })}
                                    </div>
                                </div>
                            )
                        }

                        <a
                            href="/artistes"
                            class="inline-flex items-center gap-2 mt-8 text-stone-400 hover:text-primary transition-colors"
                        >
                            <svg
                                class="w-5 h-5"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                            </svg>
                            Retour aux artistes
                        </a>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Layout>
