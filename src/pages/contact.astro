---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Contact - Chorus Symphonia">
    <Header />
    <main class="pt-20">
        <!-- Hero -->
        <section
            class="py-16 md:py-24 bg-gradient-to-b from-zinc-900 to-zinc-950"
        >
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <span
                    class="inline-block text-purple-400 font-medium uppercase tracking-wider text-sm mb-4"
                    >Nous écrire</span
                >
                <h1
                    class="font-serif text-4xl sm:text-5xl md:text-6xl font-bold text-zinc-100 mb-6"
                >
                    Contact
                </h1>
                <p class="text-zinc-400 max-w-2xl mx-auto text-lg">
                    Pour toute demande générale, veuillez utiliser le formulaire
                    ci-dessous. Nous nous engageons à vous répondre dans les
                    meilleurs délais.
                </p>
            </div>
        </section>

        <!-- Contact Section -->
        <section class="py-16 bg-zinc-950">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid lg:grid-cols-5 gap-12">
                    <!-- Contact Form -->
                    <div class="lg:col-span-3">
                        <div
                            class="bg-zinc-900 rounded-2xl p-8 border border-zinc-800"
                        >
                            <h2
                                class="font-serif text-2xl font-bold text-zinc-100 mb-2"
                            >
                                Envoyez-nous un message
                            </h2>
                            <p class="text-zinc-400 text-sm mb-8">
                                Les champs marqués d'un * sont obligatoires.
                            </p>

                            <form class="space-y-6">
                                <div class="grid sm:grid-cols-2 gap-6">
                                    <div>
                                        <label
                                            for="firstName"
                                            class="block text-zinc-300 text-sm font-medium mb-2"
                                            >Prénom *</label
                                        >
                                        <input
                                            type="text"
                                            id="firstName"
                                            name="firstName"
                                            required
                                            class="w-full px-4 py-3 rounded-lg bg-zinc-800 border border-zinc-700 text-zinc-100 placeholder:text-zinc-500 focus:outline-none focus:border-purple-500 focus:ring-2 focus:ring-purple-500/20 transition-all"
                                            placeholder="Votre prénom"
                                        />
                                    </div>
                                    <div>
                                        <label
                                            for="lastName"
                                            class="block text-zinc-300 text-sm font-medium mb-2"
                                            >Nom *</label
                                        >
                                        <input
                                            type="text"
                                            id="lastName"
                                            name="lastName"
                                            required
                                            class="w-full px-4 py-3 rounded-lg bg-zinc-800 border border-zinc-700 text-zinc-100 placeholder:text-zinc-500 focus:outline-none focus:border-purple-500 focus:ring-2 focus:ring-purple-500/20 transition-all"
                                            placeholder="Votre nom"
                                        />
                                    </div>
                                </div>

                                <div>
                                    <label
                                        for="email"
                                        class="block text-zinc-300 text-sm font-medium mb-2"
                                        >Email *</label
                                    >
                                    <input
                                        type="email"
                                        id="email"
                                        name="email"
                                        required
                                        class="w-full px-4 py-3 rounded-lg bg-zinc-800 border border-zinc-700 text-zinc-100 placeholder:text-zinc-500 focus:outline-none focus:border-purple-500 focus:ring-2 focus:ring-purple-500/20 transition-all"
                                        placeholder="votre@email.com"
                                    />
                                </div>

                                <div>
                                    <label
                                        for="phone"
                                        class="block text-zinc-300 text-sm font-medium mb-2"
                                        >Téléphone</label
                                    >
                                    <input
                                        type="tel"
                                        id="phone"
                                        name="phone"
                                        class="w-full px-4 py-3 rounded-lg bg-zinc-800 border border-zinc-700 text-zinc-100 placeholder:text-zinc-500 focus:outline-none focus:border-purple-500 focus:ring-2 focus:ring-purple-500/20 transition-all"
                                        placeholder="06 12 34 56 78"
                                    />
                                </div>

                                <div>
                                    <label
                                        for="subject"
                                        class="block text-zinc-300 text-sm font-medium mb-2"
                                        >Sujet *</label
                                    >
                                    <select
                                        id="subject"
                                        name="subject"
                                        required
                                        class="w-full px-4 py-3 rounded-lg bg-zinc-800 border border-zinc-700 text-zinc-100 focus:outline-none focus:border-purple-500 focus:ring-2 focus:ring-purple-500/20 transition-all"
                                    >
                                        <option value=""
                                            >Sélectionnez un sujet</option
                                        >
                                        <option value="billetterie"
                                            >Question sur la billetterie</option
                                        >
                                        <option value="programmation"
                                            >Question sur la programmation</option
                                        >
                                        <option value="partenariat"
                                            >Demande de partenariat</option
                                        >
                                        <option value="presse"
                                            >Accréditation presse</option
                                        >
                                        <option value="accessibilite"
                                            >Accessibilité PMR</option
                                        >
                                        <option value="autre"
                                            >Autre demande</option
                                        >
                                    </select>
                                </div>

                                <div>
                                    <label
                                        for="message"
                                        class="block text-zinc-300 text-sm font-medium mb-2"
                                        >Message *</label
                                    >
                                    <textarea
                                        id="message"
                                        name="message"
                                        rows="5"
                                        required
                                        class="w-full px-4 py-3 rounded-lg bg-zinc-800 border border-zinc-700 text-zinc-100 placeholder:text-zinc-500 focus:outline-none focus:border-purple-500 focus:ring-2 focus:ring-purple-500/20 transition-all resize-none"
                                        placeholder="Votre message..."
                                    ></textarea>
                                </div>

                                <div class="flex items-start gap-3">
                                    <input
                                        type="checkbox"
                                        id="privacy"
                                        name="privacy"
                                        required
                                        class="mt-1 w-4 h-4 rounded border-zinc-600 bg-zinc-800 text-purple-400 focus:ring-purple-500 focus:ring-offset-zinc-900"
                                    />
                                    <label
                                        for="privacy"
                                        class="text-zinc-400 text-sm"
                                    >
                                        J'accepte que mes données soient
                                        utilisées pour répondre à ma demande. *
                                        <a
                                            href="/confidentialite"
                                            class="text-purple-400 hover:text-purple-300"
                                            >Politique de confidentialité</a
                                        >
                                    </label>
                                </div>

                                <button
                                    type="submit"
                                    class="w-full inline-flex items-center justify-center gap-2 bg-purple-600 hover:bg-purple-500 text-zinc-950 font-semibold px-8 py-4 rounded-full transition-all hover:scale-105"
                                >
                                    Envoyer le message
                                    <svg
                                        class="w-5 h-5"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"
                                        ></path>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    </div>

                    <!-- Contact Info -->
                    <div class="lg:col-span-2">
                        <h2
                            class="font-serif text-2xl font-bold text-zinc-100 mb-8"
                        >
                            Vous pouvez également nous contacter au :
                        </h2>

                        <div class="space-y-6">
                            <!-- Email -->
                            <div class="flex items-start gap-4">
                                <div
                                    class="w-12 h-12 rounded-full bg-purple-600/20 flex items-center justify-center shrink-0"
                                >
                                    <svg
                                        class="w-6 h-6 text-purple-400"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                        ></path>
                                    </svg>
                                </div>
                                <div>
                                    <h3
                                        class="text-zinc-100 font-semibold mb-1"
                                    >
                                        Email
                                    </h3>
                                    <a
                                        href="mailto:contact@chorussymphonia.fr"
                                        class="text-purple-400 hover:text-purple-300 transition-colors"
                                    >
                                        contact@chorussymphonia.fr
                                    </a>
                                </div>
                            </div>

                            <!-- Phone -->
                            <div class="flex items-start gap-4">
                                <div
                                    class="w-12 h-12 rounded-full bg-purple-600/20 flex items-center justify-center shrink-0"
                                >
                                    <svg
                                        class="w-6 h-6 text-purple-400"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                        ></path>
                                    </svg>
                                </div>
                                <div>
                                    <h3
                                        class="text-zinc-100 font-semibold mb-1"
                                    >
                                        Téléphone
                                    </h3>
                                    <p class="text-zinc-400">03 13 45 85 95</p>
                                    <p class="text-zinc-500 text-sm">
                                        Du lundi au vendredi, 9h-18h
                                    </p>
                                </div>
                            </div>

                            <!-- Address -->
                            <div class="flex items-start gap-4">
                                <div
                                    class="w-12 h-12 rounded-full bg-purple-600/20 flex items-center justify-center shrink-0"
                                >
                                    <svg
                                        class="w-6 h-6 text-purple-400"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                        ></path>
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                        ></path>
                                    </svg>
                                </div>
                                <div>
                                    <h3
                                        class="text-zinc-100 font-semibold mb-1"
                                    >
                                        Adresse
                                    </h3>
                                    <p class="text-zinc-400">
                                        Festival Chorus Symphonia<br />
                                        Maison des Festivals<br />
                                        12, Rue de la Musique<br />
                                        25000 Besançon, France
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Social Links -->
                        <div class="mt-10 pt-10 border-t border-zinc-800">
                            <h3 class="text-zinc-100 font-semibold mb-4">
                                Suivez-nous sur les réseaux
                            </h3>
                            <div class="flex gap-4">
                                <a
                                    href="#"
                                    class="w-12 h-12 rounded-full bg-zinc-800 hover:bg-purple-500 hover:text-zinc-950 flex items-center justify-center text-zinc-400 transition-all"
                                    aria-label="Facebook"
                                >
                                    <svg
                                        class="w-5 h-5"
                                        fill="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                                        ></path>
                                    </svg>
                                </a>
                                <a
                                    href="#"
                                    class="w-12 h-12 rounded-full bg-zinc-800 hover:bg-purple-500 hover:text-zinc-950 flex items-center justify-center text-zinc-400 transition-all"
                                    aria-label="Instagram"
                                >
                                    <svg
                                        class="w-5 h-5"
                                        fill="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"
                                        ></path>
                                    </svg>
                                </a>
                                <a
                                    href="#"
                                    class="w-12 h-12 rounded-full bg-zinc-800 hover:bg-purple-500 hover:text-zinc-950 flex items-center justify-center text-zinc-400 transition-all"
                                    aria-label="Twitter"
                                >
                                    <svg
                                        class="w-5 h-5"
                                        fill="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                                        ></path>
                                    </svg>
                                </a>
                                <a
                                    href="#"
                                    class="w-12 h-12 rounded-full bg-zinc-800 hover:bg-purple-500 hover:text-zinc-950 flex items-center justify-center text-zinc-400 transition-all"
                                    aria-label="YouTube"
                                >
                                    <svg
                                        class="w-5 h-5"
                                        fill="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
                                        ></path>
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
    <Footer />
</Layout>
