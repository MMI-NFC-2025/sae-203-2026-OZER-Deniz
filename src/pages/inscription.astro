---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const error = Astro.url.searchParams.get("error");
const isAuthenticated = Boolean(Astro.cookies.get("pb_auth")?.value);
---

<Layout title="Inscription - Chorus Symphonia">
    <Header />

    <main class="pt-24 min-h-screen bg-zinc-950">
        <section class="py-16 md:py-24">
            <div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8">
                <div
                    class="bg-zinc-900/60 border border-zinc-800 rounded-2xl p-8 md:p-10"
                >
                    <h1
                        class="font-serif text-3xl sm:text-4xl text-zinc-100 font-bold mb-4"
                    >
                        Inscription
                    </h1>
                    <p class="text-zinc-400 mb-8">
                        Crée ton compte pour accéder à ton espace personnel.
                    </p>

                    {
                        error && (
                            <div class="mb-6 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3 text-red-300 text-sm">
                                {error === "missing-fields" &&
                                    "Merci de remplir tous les champs."}
                                {error === "password-mismatch" &&
                                    "Les mots de passe ne correspondent pas."}
                                {error === "email-already-used" &&
                                    "Cet email est déjà utilisé."}
                                {error === "register-failed" &&
                                    "Impossible de créer le compte pour le moment."}
                            </div>
                        )
                    }

                    {
                        isAuthenticated ? (
                            <div class="space-y-4">
                                <div class="rounded-lg border border-purple-500/30 bg-purple-500/10 px-4 py-3 text-purple-200 text-sm">
                                    Tu es déjà connecté.
                                </div>
                                <a
                                    href="/compte"
                                    class="inline-flex items-center justify-center px-6 py-3 rounded-full bg-purple-600 hover:bg-purple-500 text-white font-semibold transition-colors"
                                >
                                    Aller à mon compte
                                </a>
                            </div>
                        ) : (
                            <form
                                method="post"
                                action="/api/auth/register"
                                class="space-y-5"
                            >
                                <div>
                                    <label
                                        for="name"
                                        class="block text-sm font-medium text-zinc-300 mb-2"
                                    >
                                        Nom affiché
                                    </label>
                                    <input
                                        id="name"
                                        name="name"
                                        type="text"
                                        required
                                        class="w-full rounded-lg border border-zinc-700 bg-zinc-950/80 px-4 py-3 text-zinc-100 outline-none focus:border-purple-500"
                                        placeholder="Ton nom"
                                    />
                                </div>

                                <div>
                                    <label
                                        for="email"
                                        class="block text-sm font-medium text-zinc-300 mb-2"
                                    >
                                        Email
                                    </label>
                                    <input
                                        id="email"
                                        name="email"
                                        type="email"
                                        required
                                        autocomplete="email"
                                        class="w-full rounded-lg border border-zinc-700 bg-zinc-950/80 px-4 py-3 text-zinc-100 outline-none focus:border-purple-500"
                                        placeholder="ton-email@exemple.com"
                                    />
                                </div>

                                <div>
                                    <label
                                        for="password"
                                        class="block text-sm font-medium text-zinc-300 mb-2"
                                    >
                                        Mot de passe
                                    </label>
                                    <input
                                        id="password"
                                        name="password"
                                        type="password"
                                        required
                                        minlength="8"
                                        autocomplete="new-password"
                                        class="w-full rounded-lg border border-zinc-700 bg-zinc-950/80 px-4 py-3 text-zinc-100 outline-none focus:border-purple-500"
                                        placeholder="Minimum 8 caractères"
                                    />
                                </div>

                                <div>
                                    <label
                                        for="passwordConfirm"
                                        class="block text-sm font-medium text-zinc-300 mb-2"
                                    >
                                        Confirme le mot de passe
                                    </label>
                                    <input
                                        id="passwordConfirm"
                                        name="passwordConfirm"
                                        type="password"
                                        required
                                        minlength="8"
                                        autocomplete="new-password"
                                        class="w-full rounded-lg border border-zinc-700 bg-zinc-950/80 px-4 py-3 text-zinc-100 outline-none focus:border-purple-500"
                                        placeholder="Répète ton mot de passe"
                                    />
                                </div>

                                <button
                                    type="submit"
                                    class="w-full inline-flex items-center justify-center px-6 py-3 rounded-full bg-purple-600 hover:bg-purple-500 text-white font-semibold transition-colors"
                                >
                                    Créer mon compte
                                </button>
                            </form>
                        )
                    }

                    <p class="mt-8 text-sm text-zinc-400">
                        Déjà inscrit ?
                        <a
                            href="/connexion"
                            class="text-purple-400 hover:text-purple-300"
                            >Se connecter</a
                        >
                    </p>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Layout>
