---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getArtistes, getImageUrl } from "../../backend/backend.mjs";

const artistes = await getArtistes();
---

<Layout
    title="Artistes - Chorus Symphonia"
    description="Decouvrez les artistes du festival Chorus Symphonia 2026"
>
    <Header />

    <main class="pt-24">
        <section class="relative py-20 bg-zinc-900">
            <div
                class="absolute inset-0 bg-gradient-to-b from-zinc-950/80 to-zinc-900"
            >
            </div>
            <div
                class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center"
            >
                <h1
                    class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6"
                >
                    Nos <span class="text-purple-400">Artistes</span>
                </h1>
                <p class="text-xl text-zinc-300 max-w-3xl mx-auto">
                    Des musiciens d'exception reunis pour celebrer la musique
                    classique
                </p>
            </div>
        </section>

        <section class="py-20 bg-zinc-950">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                {
                    artistes.length > 0 ? (
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                            {artistes.map((artiste) => {
                                const imageUrl = artiste.photo
                                    ? getImageUrl(artiste, artiste.photo)
                                    : null;
                                return (
                                    <a
                                        href={`/artistes/${artiste.id}`}
                                        class="group bg-zinc-900 rounded-xl overflow-hidden hover:bg-zinc-800 transition-all duration-300 hover:shadow-xl hover:shadow-purple-500/10 hover:-translate-y-1"
                                    >
                                        <div class="aspect-[3/4] relative overflow-hidden">
                                            {imageUrl ? (
                                                <img
                                                    src={imageUrl}
                                                    alt={artiste.nom}
                                                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                                />
                                            ) : (
                                                <div class="w-full h-full bg-zinc-800 flex items-center justify-center">
                                                    <svg
                                                        class="w-24 h-24 text-zinc-600"
                                                        fill="none"
                                                        viewBox="0 0 24 24"
                                                        stroke="currentColor"
                                                    >
                                                        <path
                                                            stroke-linecap="round"
                                                            stroke-linejoin="round"
                                                            stroke-width="1.5"
                                                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                                                        />
                                                    </svg>
                                                </div>
                                            )}
                                            <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-transparent to-transparent opacity-60" />
                                        </div>
                                        <div class="p-6">
                                            <h3 class="font-serif text-xl font-bold text-white mb-2 group-hover:text-purple-400 transition-colors">
                                                {artiste.nom}
                                            </h3>
                                            {artiste.instrument && (
                                                <p class="text-purple-400 text-sm font-medium mb-3">
                                                    {artiste.instrument}
                                                </p>
                                            )}
                                            {artiste.bio && (
                                                <p class="text-zinc-400 text-sm line-clamp-3">
                                                    {artiste.bio}
                                                </p>
                                            )}
                                        </div>
                                    </a>
                                );
                            })}
                        </div>
                    ) : (
                        <div class="text-center py-20">
                            <svg
                                class="w-16 h-16 text-zinc-600 mx-auto mb-6"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="1.5"
                                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                                />
                            </svg>
                            <h3 class="font-serif text-2xl font-bold text-white mb-4">
                                Aucun artiste disponible
                            </h3>
                            <p class="text-zinc-400 max-w-md mx-auto">
                                Les artistes seront bientot annonces. Revenez
                                regulierement pour decouvrir notre
                                programmation.
                            </p>
                        </div>
                    )
                }
            </div>
        </section>
    </main>

    <Footer />
</Layout>

<style>
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
