---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getScenes, getImageUrl } from "../../backend/backend.mjs";

const scenes = await getScenes();
---

<Layout
    title="Scènes - Chorus Symphonia"
    description="Découvrez les scènes du festival Chorus Symphonia 2026 à la Citadelle de Besançon"
>
    <Header />

    <main class="pt-24">
        <!-- Hero Section -->
        <section class="relative py-20 bg-zinc-900">
            <div
                class="absolute inset-0 bg-gradient-to-b from-zinc-950/80 to-zinc-900"
            >
            </div>
            <div
                class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center"
            >
                <h1
                    class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6"
                >
                    Les <span class="text-purple-400">Scènes</span>
                </h1>
                <p class="text-xl text-zinc-300 max-w-3xl mx-auto">
                    Des lieux d'exception au cœur de la Citadelle Vauban pour
                    des expériences musicales uniques
                </p>
            </div>
        </section>

        <!-- Scenes Grid -->
        <section class="py-20 bg-zinc-950">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                {
                    scenes.length > 0 ? (
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            {scenes.map((scene) => {
                                const imageUrl = scene.image
                                    ? getImageUrl(scene, scene.image)
                                    : null;
                                return (
                                    <a
                                        href={`/scenes/${scene.id}`}
                                        class="group relative bg-zinc-900 rounded-2xl overflow-hidden hover:shadow-2xl hover:shadow-purple-500/10 transition-all duration-500"
                                    >
                                        <div class="aspect-[16/9] relative overflow-hidden">
                                            {imageUrl ? (
                                                <img
                                                    src={imageUrl}
                                                    alt={scene.nom}
                                                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                                                />
                                            ) : (
                                                <div class="w-full h-full bg-zinc-800 flex items-center justify-center">
                                                    <svg
                                                        class="w-20 h-20 text-zinc-600"
                                                        fill="none"
                                                        viewBox="0 0 24 24"
                                                        stroke="currentColor"
                                                    >
                                                        <path
                                                            stroke-linecap="round"
                                                            stroke-linejoin="round"
                                                            stroke-width="1.5"
                                                            d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                                                        />
                                                    </svg>
                                                </div>
                                            )}
                                            <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/50 to-transparent" />
                                        </div>
                                        <div class="absolute bottom-0 left-0 right-0 p-8">
                                            <div class="flex items-end justify-between gap-4">
                                                <div>
                                                    <h3 class="font-serif text-2xl md:text-3xl font-bold text-white mb-2 group-hover:text-purple-400 transition-colors">
                                                        {scene.nom}
                                                    </h3>
                                                    {scene.capacite && (
                                                        <p class="text-zinc-400 flex items-center gap-2">
                                                            <svg
                                                                class="w-4 h-4"
                                                                fill="none"
                                                                viewBox="0 0 24 24"
                                                                stroke="currentColor"
                                                            >
                                                                <path
                                                                    stroke-linecap="round"
                                                                    stroke-linejoin="round"
                                                                    stroke-width="2"
                                                                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
                                                                />
                                                            </svg>
                                                            {scene.capacite}{" "}
                                                            places
                                                        </p>
                                                    )}
                                                </div>
                                                <div class="w-12 h-12 rounded-full bg-purple-600/20 flex items-center justify-center group-hover:bg-purple-500 transition-colors">
                                                    <svg
                                                        class="w-6 h-6 text-purple-400 group-hover:text-zinc-950 transition-colors"
                                                        fill="none"
                                                        viewBox="0 0 24 24"
                                                        stroke="currentColor"
                                                    >
                                                        <path
                                                            stroke-linecap="round"
                                                            stroke-linejoin="round"
                                                            stroke-width="2"
                                                            d="M9 5l7 7-7 7"
                                                        />
                                                    </svg>
                                                </div>
                                            </div>
                                        </div>
                                    </a>
                                );
                            })}
                        </div>
                    ) : (
                        <div class="text-center py-20">
                            <svg
                                class="w-16 h-16 text-zinc-600 mx-auto mb-6"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="1.5"
                                    d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                                />
                            </svg>
                            <h3 class="font-serif text-2xl font-bold text-white mb-4">
                                Aucune scène disponible
                            </h3>
                            <p class="text-zinc-400 max-w-md mx-auto">
                                Les scènes seront bientôt dévoilées. Revenez
                                régulièrement pour découvrir les lieux du
                                festival.
                            </p>
                        </div>
                    )
                }
            </div>
        </section>

        <!-- Citadelle Info -->
        <section class="py-20 bg-zinc-900">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div
                    class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center"
                >
                    <div>
                        <span class="text-purple-400 font-medium mb-4 block"
                            >UNESCO</span
                        >
                        <h2
                            class="font-serif text-3xl md:text-4xl font-bold text-white mb-6"
                        >
                            La Citadelle de Besançon
                        </h2>
                        <p class="text-zinc-300 text-lg leading-relaxed mb-6">
                            Chef-d'œuvre de Vauban inscrit au patrimoine mondial
                            de l'UNESCO, la Citadelle de Besançon offre un cadre
                            exceptionnel pour vivre des moments musicaux
                            inoubliables.
                        </p>
                        <p class="text-zinc-400 leading-relaxed mb-8">
                            Ses différents espaces - cours intérieures, salles
                            voûtées, espaces en plein air - permettent
                            d'accueillir des formations allant du trio intimiste
                            au grand orchestre symphonique.
                        </p>
                        <a
                            href="/infos-pratiques"
                            class="inline-flex items-center gap-2 px-6 py-3 bg-purple-600 text-zinc-950 rounded-lg font-medium hover:bg-purple-500/90 transition-colors"
                        >
                            Informations pratiques
                            <svg
                                class="w-5 h-5"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                            </svg>
                        </a>
                    </div>
                    <div class="relative">
                        <div
                            class="aspect-[4/3] rounded-2xl overflow-hidden bg-zinc-800"
                        >
                            <img
                                src="https://images.unsplash.com/photo-1582555172866-f73bb12a2ab3?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80"
                                alt="Vue de la Citadelle de Besançon"
                                class="w-full h-full object-cover"
                            />
                        </div>
                        <div
                            class="absolute -z-10 -bottom-6 -right-6 w-full h-full bg-purple-600/20 rounded-2xl"
                        >
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Layout>
