---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const passes = [
    {
        name: "Pass Journée",
        description: "Accès à tous les concerts d'une journée de votre choix",
        price: "89€",
        features: [
            "Accès à tous les concerts du jour",
            "Places en catégorie 2",
            "Navette gratuite",
            "Programme officiel offert",
        ],
        popular: false,
    },
    {
        name: "Pass Festival",
        description: "L'expérience complète sur les 4 jours du festival",
        price: "249€",
        features: [
            "Accès à TOUS les concerts",
            "Places en catégorie 1",
            "Navette gratuite",
            "Programme officiel offert",
            "Accès aux masterclasses",
            "Cocktail de bienvenue",
            "Rencontres avec les artistes",
        ],
        popular: true,
    },
    {
        name: "Pass VIP",
        description: "Une expérience privilégiée et exclusive",
        price: "449€",
        features: [
            "Tous les avantages Pass Festival",
            "Places premières loges",
            "Lounge VIP privatif",
            "Dîner gastronomique inclus",
            "Visite privée de la Citadelle",
            "Cadeau souvenir exclusif",
        ],
        popular: false,
    },
];

const tickets = [
    {
        concert: "Concert d'ouverture - 28 Août",
        cat1: "85€",
        cat2: "65€",
        cat3: "45€",
    },
    {
        concert: "Récital Piano Buniatishvili - 29 Août",
        cat1: "90€",
        cat2: "70€",
        cat3: "50€",
    },
    {
        concert: "Musique de chambre - 30 Août",
        cat1: "75€",
        cat2: "55€",
        cat3: "45€",
    },
    {
        concert: "Concert de clôture - 31 Août",
        cat1: "95€",
        cat2: "75€",
        cat3: "55€",
    },
];
---

<Layout title="Billetterie - Chorus Symphonia">
    <Header />
    <main class="pt-20">
        <!-- Hero -->
        <section
            class="py-16 md:py-24 bg-gradient-to-b from-zinc-900 to-zinc-950"
        >
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <span
                    class="inline-block text-purple-400 font-medium uppercase tracking-wider text-sm mb-4"
                    >Réservation</span
                >
                <h1
                    class="font-serif text-4xl sm:text-5xl md:text-6xl font-bold text-zinc-100 mb-6"
                >
                    Billetterie
                </h1>
                <p class="text-zinc-400 max-w-2xl mx-auto text-lg">
                    Réservez vos places pour le Festival Chorus Symphonia 2026
                    et vivez des moments musicaux inoubliables.
                </p>
            </div>
        </section>

        <!-- Pass Section -->
        <section class="py-16 bg-zinc-950">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-12">
                    <h2
                        class="font-serif text-3xl font-bold text-zinc-100 mb-4"
                    >
                        Nos Pass
                    </h2>
                    <p class="text-zinc-400">
                        Choisissez la formule qui vous convient le mieux
                    </p>
                </div>

                <div class="grid md:grid-cols-3 gap-8">
                    {
                        passes.map((pass) => (
                            <div
                                class={`relative rounded-2xl p-8 ${pass.popular ? "bg-gradient-to-b from-primary/20 to-zinc-900 border-2 border-purple-500" : "bg-zinc-900 border border-zinc-800"}`}
                            >
                                {pass.popular && (
                                    <div class="absolute -top-4 left-1/2 -translate-x-1/2">
                                        <span class="bg-purple-600 text-zinc-950 text-xs font-bold uppercase tracking-wider px-4 py-1.5 rounded-full">
                                            Le plus populaire
                                        </span>
                                    </div>
                                )}

                                <div class="text-center mb-8">
                                    <h3 class="font-serif text-2xl font-bold text-zinc-100 mb-2">
                                        {pass.name}
                                    </h3>
                                    <p class="text-zinc-400 text-sm mb-4">
                                        {pass.description}
                                    </p>
                                    <div class="flex items-baseline justify-center gap-1">
                                        <span class="font-serif text-5xl font-bold text-purple-400">
                                            {pass.price}
                                        </span>
                                    </div>
                                </div>

                                <ul class="space-y-4 mb-8">
                                    {pass.features.map((feature) => (
                                        <li class="flex items-start gap-3">
                                            <svg
                                                class="w-5 h-5 text-purple-400 shrink-0 mt-0.5"
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M5 13l4 4L19 7"
                                                />
                                            </svg>
                                            <span class="text-zinc-300 text-sm">
                                                {feature}
                                            </span>
                                        </li>
                                    ))}
                                </ul>

                                <button
                                    class={`w-full py-4 rounded-full font-semibold transition-all hover:scale-105 ${pass.popular ? "bg-purple-600 hover:bg-purple-500 text-zinc-950" : "bg-zinc-800 hover:bg-zinc-700 text-zinc-100"}`}
                                >
                                    Réserver
                                </button>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- Individual Tickets -->
        <section class="py-16 bg-zinc-900">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-12">
                    <h2
                        class="font-serif text-3xl font-bold text-zinc-100 mb-4"
                    >
                        Billets à l'unité
                    </h2>
                    <p class="text-zinc-400">
                        Réservez vos places pour un concert spécifique
                    </p>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-zinc-700">
                                <th
                                    class="text-left py-4 px-4 text-zinc-400 font-medium text-sm"
                                    >Concert</th
                                >
                                <th
                                    class="text-center py-4 px-4 text-zinc-400 font-medium text-sm"
                                    >Cat. 1</th
                                >
                                <th
                                    class="text-center py-4 px-4 text-zinc-400 font-medium text-sm"
                                    >Cat. 2</th
                                >
                                <th
                                    class="text-center py-4 px-4 text-zinc-400 font-medium text-sm"
                                    >Cat. 3</th
                                >
                                <th class="text-center py-4 px-4"></th>
                            </tr>
                        </thead>
                        <tbody>
                            {
                                tickets.map((ticket) => (
                                    <tr class="border-b border-zinc-800 hover:bg-zinc-800/50 transition-colors">
                                        <td class="py-6 px-4 text-zinc-100 font-medium">
                                            {ticket.concert}
                                        </td>
                                        <td class="py-6 px-4 text-center text-purple-400 font-semibold">
                                            {ticket.cat1}
                                        </td>
                                        <td class="py-6 px-4 text-center text-purple-400 font-semibold">
                                            {ticket.cat2}
                                        </td>
                                        <td class="py-6 px-4 text-center text-purple-400 font-semibold">
                                            {ticket.cat3}
                                        </td>
                                        <td class="py-6 px-4 text-center">
                                            <button class="inline-flex items-center gap-2 bg-purple-600 hover:bg-purple-500 text-zinc-950 font-medium px-5 py-2 rounded-full transition-all hover:scale-105 text-sm">
                                                Réserver
                                            </button>
                                        </td>
                                    </tr>
                                ))
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Legend -->
                <div
                    class="mt-8 flex flex-wrap gap-6 justify-center text-sm text-zinc-400"
                >
                    <div class="flex items-center gap-2">
                        <span class="w-4 h-4 rounded-full bg-purple-600/80"></span>
                        <span>Cat. 1 - Premières loges</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="w-4 h-4 rounded-full bg-purple-600/50"></span>
                        <span>Cat. 2 - Carré d'or</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="w-4 h-4 rounded-full bg-purple-600/30"></span>
                        <span>Cat. 3 - Tribune</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Info Section -->
        <section class="py-16 bg-zinc-950">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid md:grid-cols-2 gap-8">
                    <div
                        class="bg-zinc-900 rounded-2xl p-8 border border-zinc-800"
                    >
                        <div
                            class="w-12 h-12 rounded-full bg-purple-600/20 flex items-center justify-center mb-4"
                        >
                            <svg
                                class="w-6 h-6 text-purple-400"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="font-serif text-xl font-semibold text-zinc-100 mb-3"
                        >
                            Informations pratiques
                        </h3>
                        <ul class="space-y-2 text-zinc-400 text-sm">
                            <li>
                                Les billets sont nominatifs et non remboursables
                            </li>
                            <li>
                                Ouverture des portes 45 minutes avant le concert
                            </li>
                            <li>Placement libre en catégorie 3</li>
                            <li>
                                Les enfants de moins de 6 ans ne sont pas admis
                            </li>
                        </ul>
                    </div>

                    <div
                        class="bg-zinc-900 rounded-2xl p-8 border border-zinc-800"
                    >
                        <div
                            class="w-12 h-12 rounded-full bg-purple-600/20 flex items-center justify-center mb-4"
                        >
                            <svg
                                class="w-6 h-6 text-purple-400"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="font-serif text-xl font-semibold text-zinc-100 mb-3"
                        >
                            Moyens de paiement
                        </h3>
                        <ul class="space-y-2 text-zinc-400 text-sm">
                            <li>
                                Carte bancaire (Visa, Mastercard, American
                                Express)
                            </li>
                            <li>PayPal</li>
                            <li>Chèques vacances (sur place uniquement)</li>
                            <li>Paiement sécurisé SSL</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>
    </main>
    <Footer />
</Layout>
