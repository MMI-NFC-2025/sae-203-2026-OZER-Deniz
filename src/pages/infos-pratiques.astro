---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Infos Pratiques - Chorus Symphonia">
    <Header />
    <main class="pt-20">
        <!-- Hero -->
        <section
            class="py-16 md:py-24 bg-gradient-to-b from-zinc-900 to-zinc-950"
        >
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <span
                    class="inline-block text-purple-400 font-medium uppercase tracking-wider text-sm mb-4"
                    >Préparez votre venue</span
                >
                <h1
                    class="font-serif text-4xl sm:text-5xl md:text-6xl font-bold text-zinc-100 mb-6"
                >
                    Infos Pratiques
                </h1>
                <p class="text-zinc-400 max-w-2xl mx-auto text-lg">
                    Tout ce que vous devez savoir pour profiter pleinement du
                    festival.
                </p>
            </div>
        </section>

        <!-- Access Section -->
        <section class="py-16 bg-zinc-950">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid lg:grid-cols-2 gap-12 items-start">
                    <!-- Map / Image -->
                    <div class="order-2 lg:order-1">
                        <div
                            class="aspect-[4/3] rounded-2xl overflow-hidden bg-zinc-800"
                        >
                            <iframe
                                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2708.5!2d6.0333!3d47.2333!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x478d63c8b0000001%3A0x0!2sCitadelle%20de%20Besan%C3%A7on!5e0!3m2!1sfr!2sfr!4v1234567890"
                                width="100%"
                                height="100%"
                                style="border:0;"
                                allowfullscreen=""
                                loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade"
                                class="grayscale"></iframe>
                        </div>
                    </div>

                    <!-- Content -->
                    <div class="order-1 lg:order-2">
                        <h2
                            class="font-serif text-3xl font-bold text-zinc-100 mb-8"
                        >
                            Comment venir
                        </h2>

                        <!-- En voiture -->
                        <div class="mb-8">
                            <div class="flex items-start gap-4 mb-4">
                                <div
                                    class="w-10 h-10 rounded-full bg-purple-600/20 flex items-center justify-center shrink-0"
                                >
                                    <svg
                                        class="w-5 h-5 text-purple-400"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"
                                        ></path>
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"
                                        ></path>
                                    </svg>
                                </div>
                                <div>
                                    <h3
                                        class="text-zinc-100 font-semibold mb-2"
                                    >
                                        En voiture
                                    </h3>
                                    <p
                                        class="text-zinc-400 text-sm leading-relaxed"
                                    >
                                        Autoroute A36, sortie Besançon Centre.
                                        Suivre les indications "Citadelle".
                                        Parking gratuit à 500m du site avec
                                        navettes.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- En train -->
                        <div class="mb-8">
                            <div class="flex items-start gap-4 mb-4">
                                <div
                                    class="w-10 h-10 rounded-full bg-purple-600/20 flex items-center justify-center shrink-0"
                                >
                                    <svg
                                        class="w-5 h-5 text-purple-400"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"
                                        ></path>
                                    </svg>
                                </div>
                                <div>
                                    <h3
                                        class="text-zinc-100 font-semibold mb-2"
                                    >
                                        En train
                                    </h3>
                                    <p
                                        class="text-zinc-400 text-sm leading-relaxed"
                                    >
                                        Gare de Besançon Viotte (TER) ou
                                        Besançon Franche-Comté TGV (LGV).
                                        Navettes gratuites depuis les deux gares
                                        pendant le festival.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Navettes -->
                        <div class="mb-8">
                            <div class="flex items-start gap-4 mb-4">
                                <div
                                    class="w-10 h-10 rounded-full bg-purple-600/20 flex items-center justify-center shrink-0"
                                >
                                    <svg
                                        class="w-5 h-5 text-purple-400"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"
                                        ></path>
                                    </svg>
                                </div>
                                <div>
                                    <h3
                                        class="text-zinc-100 font-semibold mb-2"
                                    >
                                        Navettes gratuites
                                    </h3>
                                    <p
                                        class="text-zinc-400 text-sm leading-relaxed"
                                    >
                                        Service de navettes gratuites depuis le
                                        centre-ville, les parkings relais et les
                                        gares. Départ toutes les 15 minutes, de
                                        17h à minuit.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Adresse -->
                        <div
                            class="bg-zinc-900 rounded-xl p-6 border border-zinc-800"
                        >
                            <h3 class="text-zinc-100 font-semibold mb-3">
                                Adresse du festival
                            </h3>
                            <p class="text-zinc-400 text-sm">
                                Citadelle de Besançon<br />
                                99, rue des Fusillés de la Résistance<br />
                                25000 Besançon, France
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Practical Info Grid -->
        <section class="py-16 bg-zinc-900">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <h2
                    class="font-serif text-3xl font-bold text-zinc-100 mb-12 text-center"
                >
                    Sur place
                </h2>

                <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    <!-- Horaires -->
                    <div
                        class="bg-zinc-950 rounded-2xl p-6 border border-zinc-800"
                    >
                        <div
                            class="w-12 h-12 rounded-full bg-purple-600/20 flex items-center justify-center mb-4"
                        >
                            <svg
                                class="w-6 h-6 text-purple-400"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="font-serif text-xl font-semibold text-zinc-100 mb-3"
                        >
                            Horaires
                        </h3>
                        <ul class="space-y-2 text-zinc-400 text-sm">
                            <li>Ouverture du site : 16h00</li>
                            <li>Fermeture : 00h30</li>
                            <li>Ouverture des salles : 45 min avant</li>
                        </ul>
                    </div>

                    <!-- Restauration -->
                    <div
                        class="bg-zinc-950 rounded-2xl p-6 border border-zinc-800"
                    >
                        <div
                            class="w-12 h-12 rounded-full bg-purple-600/20 flex items-center justify-center mb-4"
                        >
                            <svg
                                class="w-6 h-6 text-purple-400"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="font-serif text-xl font-semibold text-zinc-100 mb-3"
                        >
                            Restauration
                        </h3>
                        <ul class="space-y-2 text-zinc-400 text-sm">
                            <li>Food trucks gastronomiques</li>
                            <li>Bar à vins et champagne</li>
                            <li>Espaces pique-nique</li>
                            <li>Options végétariennes disponibles</li>
                        </ul>
                    </div>

                    <!-- Accessibilité -->
                    <div
                        class="bg-zinc-950 rounded-2xl p-6 border border-zinc-800"
                    >
                        <div
                            class="w-12 h-12 rounded-full bg-purple-600/20 flex items-center justify-center mb-4"
                        >
                            <svg
                                class="w-6 h-6 text-purple-400"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="font-serif text-xl font-semibold text-zinc-100 mb-3"
                        >
                            Accessibilité PMR
                        </h3>
                        <ul class="space-y-2 text-zinc-400 text-sm">
                            <li>Accès adapté sur le site</li>
                            <li>Places réservées en salle</li>
                            <li>Navettes accessibles</li>
                            <li>Accompagnateur gratuit</li>
                        </ul>
                    </div>

                    <!-- Consignes -->
                    <div
                        class="bg-zinc-950 rounded-2xl p-6 border border-zinc-800"
                    >
                        <div
                            class="w-12 h-12 rounded-full bg-purple-600/20 flex items-center justify-center mb-4"
                        >
                            <svg
                                class="w-6 h-6 text-purple-400"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="font-serif text-xl font-semibold text-zinc-100 mb-3"
                        >
                            Consignes
                        </h3>
                        <ul class="space-y-2 text-zinc-400 text-sm">
                            <li>Vestiaire gratuit</li>
                            <li>Consignes pour sacs</li>
                            <li>Casiers sécurisés</li>
                        </ul>
                    </div>

                    <!-- Sécurité -->
                    <div
                        class="bg-zinc-950 rounded-2xl p-6 border border-zinc-800"
                    >
                        <div
                            class="w-12 h-12 rounded-full bg-purple-600/20 flex items-center justify-center mb-4"
                        >
                            <svg
                                class="w-6 h-6 text-purple-400"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="font-serif text-xl font-semibold text-zinc-100 mb-3"
                        >
                            Sécurité
                        </h3>
                        <ul class="space-y-2 text-zinc-400 text-sm">
                            <li>Contrôle des sacs à l'entrée</li>
                            <li>Équipe de sécurité présente</li>
                            <li>Poste de secours sur site</li>
                        </ul>
                    </div>

                    <!-- Hébergement -->
                    <div
                        class="bg-zinc-950 rounded-2xl p-6 border border-zinc-800"
                    >
                        <div
                            class="w-12 h-12 rounded-full bg-purple-600/20 flex items-center justify-center mb-4"
                        >
                            <svg
                                class="w-6 h-6 text-purple-400"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="font-serif text-xl font-semibold text-zinc-100 mb-3"
                        >
                            Hébergement
                        </h3>
                        <ul class="space-y-2 text-zinc-400 text-sm">
                            <li>Hôtels partenaires -10%</li>
                            <li>Code promo : CHORUS2026</li>
                            <li>Camping à proximité</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- FAQ -->
        <section class="py-16 bg-zinc-950">
            <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
                <h2
                    class="font-serif text-3xl font-bold text-zinc-100 mb-12 text-center"
                >
                    Questions fréquentes
                </h2>

                <div class="space-y-4">
                    <details
                        class="group bg-zinc-900 rounded-xl border border-zinc-800"
                    >
                        <summary
                            class="flex items-center justify-between p-6 cursor-pointer"
                        >
                            <span class="font-medium text-zinc-100"
                                >Puis-je sortir et revenir pendant le festival ?</span
                            >
                            <svg
                                class="w-5 h-5 text-purple-400 group-open:rotate-180 transition-transform"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </summary>
                        <div class="px-6 pb-6 text-zinc-400 text-sm">
                            Oui, votre bracelet d'entrée vous permet de sortir
                            et revenir autant de fois que vous le souhaitez
                            pendant la journée.
                        </div>
                    </details>

                    <details
                        class="group bg-zinc-900 rounded-xl border border-zinc-800"
                    >
                        <summary
                            class="flex items-center justify-between p-6 cursor-pointer"
                        >
                            <span class="font-medium text-zinc-100"
                                >Les enfants sont-ils acceptés ?</span
                            >
                            <svg
                                class="w-5 h-5 text-purple-400 group-open:rotate-180 transition-transform"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </summary>
                        <div class="px-6 pb-6 text-zinc-400 text-sm">
                            Les enfants de moins de 6 ans ne sont pas admis aux
                            concerts du soir. Des concerts "jeune public" sont
                            programmés les après-midis.
                        </div>
                    </details>

                    <details
                        class="group bg-zinc-900 rounded-xl border border-zinc-800"
                    >
                        <summary
                            class="flex items-center justify-between p-6 cursor-pointer"
                        >
                            <span class="font-medium text-zinc-100"
                                >Y a-t-il une tenue vestimentaire exigée ?</span
                            >
                            <svg
                                class="w-5 h-5 text-purple-400 group-open:rotate-180 transition-transform"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </summary>
                        <div class="px-6 pb-6 text-zinc-400 text-sm">
                            Aucune tenue particulière n'est exigée. Nous vous
                            conseillons cependant de prévoir une tenue
                            confortable et une veste pour les soirées en plein
                            air.
                        </div>
                    </details>

                    <details
                        class="group bg-zinc-900 rounded-xl border border-zinc-800"
                    >
                        <summary
                            class="flex items-center justify-between p-6 cursor-pointer"
                        >
                            <span class="font-medium text-zinc-100"
                                >Que faire en cas d'intempéries ?</span
                            >
                            <svg
                                class="w-5 h-5 text-purple-400 group-open:rotate-180 transition-transform"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </summary>
                        <div class="px-6 pb-6 text-zinc-400 text-sm">
                            Les concerts en plein air sont maintenus sauf en cas
                            de conditions météorologiques dangereuses. Des
                            espaces couverts de repli sont prévus.
                        </div>
                    </details>
                </div>
            </div>
        </section>

        <!-- Contact CTA -->
        <section class="py-16 bg-zinc-900">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <h2 class="font-serif text-3xl font-bold text-zinc-100 mb-4">
                    Une question ?
                </h2>
                <p class="text-zinc-400 mb-8">
                    Notre équipe est à votre disposition pour répondre à toutes
                    vos interrogations.
                </p>
                <a
                    href="/contact"
                    class="inline-flex items-center gap-2 bg-purple-600 hover:bg-purple-500 text-zinc-950 font-semibold px-8 py-4 rounded-full transition-all hover:scale-105"
                >
                    Nous contacter
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                </a>
            </div>
        </section>
    </main>
    <Footer />
</Layout>
