---

---

<section class="py-24 bg-zinc-950 relative overflow-hidden">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div
            class="bg-gradient-to-br from-zinc-800/80 to-zinc-900/80 rounded-3xl p-8 md:p-12 border border-zinc-700/50 backdrop-blur-sm"
        >
            <div class="text-center mb-8">
                <div
                    class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-purple-500/20 mb-6"
                >
                    <svg
                        class="w-8 h-8 text-purple-400"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                        ></path>
                    </svg>
                </div>
                <h2
                    class="font-serif text-3xl sm:text-4xl font-bold text-zinc-100 mb-4"
                >
                    Restez informe
                </h2>
                <p class="text-zinc-400 max-w-xl mx-auto">
                    Inscrivez-vous a notre newsletter pour recevoir en
                    avant-premiere toutes les actualites du festival, les
                    annonces d'artistes et les offres exclusives.
                </p>
            </div>

            <form class="flex flex-col sm:flex-row gap-4 max-w-lg mx-auto">
                <input
                    type="email"
                    placeholder="Votre adresse email"
                    required
                    class="flex-1 px-6 py-4 rounded-full bg-zinc-700/50 border border-zinc-600/50 text-zinc-100 placeholder:text-zinc-500 focus:outline-none focus:border-purple-500 focus:ring-2 focus:ring-purple-500/20 transition-all"
                />
                <button
                    type="submit"
                    class="inline-flex items-center justify-center gap-2 bg-purple-600 hover:bg-purple-500 text-white font-semibold px-8 py-4 rounded-full transition-all hover:scale-105 shrink-0"
                >
                    S'inscrire
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                </button>
            </form>

            <p class="text-zinc-500 text-xs text-center mt-6">
                En vous inscrivant, vous acceptez de recevoir nos
                communications. Vous pouvez vous desinscrire a tout moment.
            </p>
        </div>
    </div>
</section>
