---
import logoBlanc from "../assets/icon/logo-blanc.svg";
---

<section
    class="relative min-h-screen flex items-center justify-center overflow-hidden"
>
    <div class="absolute inset-0 z-0">
        <img
            src="https://images.unsplash.com/photo-1507838153414-b4b713384a76?auto=format&fit=crop&w=2000&q=80"
            alt="Orchestre symphonique"
            class="w-full h-full object-cover"
        />
        <div
            class="absolute inset-0 bg-gradient-to-b from-zinc-950/90 via-zinc-950/75 to-zinc-950"
        >
        </div>
        <div class="absolute inset-0 bg-zinc-950/35"></div>
        <div class="absolute inset-0 bg-purple-900/20"></div>
    </div>

    <div
        class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center pt-24 pb-16"
    >
        <div
            class="inline-flex items-center gap-2 bg-purple-500/20 backdrop-blur-sm border border-purple-500/30 rounded-full px-6 py-2 mb-8 animate-fade-in-up"
        >
            <svg
                class="w-5 h-5 text-purple-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                ></path>
            </svg>
            <span class="text-purple-300 font-medium">28 - 31 Aout 2026</span>
        </div>

        <img
            src={logoBlanc.src}
            alt="Chorus Symphonia"
            class="h-48 sm:h-56 md:h-72 lg:h-[22rem] w-auto mx-auto mb-6 animate-fade-in-up animation-delay-200 drop-shadow-[0_12px_28px_rgba(0,0,0,0.65)]"
        />

        <p
            class="text-lg sm:text-xl text-zinc-400 max-w-2xl mx-auto mb-10 animate-fade-in-up animation-delay-400 leading-relaxed"
        >
            Vivez une experience musicale exceptionnelle au coeur d'un site
            classe UNESCO. Quatre jours de concerts, de rencontres et
            d'emotions.
        </p>

        <div
            class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-in-up animation-delay-600"
        >
            <a
                href="/billetterie"
                class="inline-flex items-center justify-center gap-2 bg-purple-600 hover:bg-purple-500 text-white font-semibold px-8 py-4 rounded-full transition-all hover:scale-105"
            >
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"
                    ></path>
                </svg>
                Reserver mes billets
            </a>
            <a
                href="/programmation"
                class="inline-flex items-center justify-center gap-2 bg-zinc-100/10 hover:bg-zinc-100/20 text-zinc-100 font-semibold px-8 py-4 rounded-full border border-zinc-100/20 transition-all backdrop-blur-sm"
            >
                Decouvrir le programme
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
            </a>
        </div>
    </div>

    <div
        class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce"
    >
        <svg
            class="w-6 h-6 text-zinc-500"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
    </div>
</section>
