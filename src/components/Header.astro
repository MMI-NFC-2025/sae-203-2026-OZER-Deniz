---
import logoBlanc from "../assets/icon/logo-blanc.svg";
import PocketBase from "pocketbase";

const navItems = [
    { label: "Programmation", href: "/programmation" },
    { label: "Artistes", href: "/artistes" },
    { label: "Scènes", href: "/scenes" },
    { label: "Billetterie", href: "/billetterie" },
    { label: "Infos Pratiques", href: "/infos-pratiques" },
    { label: "Contact", href: "/contact" },
];

const guestItems = [
    { label: "Inscription", href: "/inscription" },
    { label: "Connexion", href: "/connexion" },
];

const pb = new PocketBase("http://127.0.0.1:8090");
pb.authStore.loadFromCookie(Astro.request.headers.get("cookie") || "");

const isAuthenticated = Boolean(pb.authStore.isValid && pb.authStore.model);
const authUser = (pb.authStore.model || null) as {
    id: string;
    avatar?: string;
} | null;
const profilePhotoUrl =
    authUser?.avatar && authUser.avatar.length > 0
        ? pb.files.getURL(authUser, authUser.avatar, { thumb: "100x100" })
        : null;
---

<header
    class="fixed top-0 left-0 right-0 z-50 bg-zinc-950/90 backdrop-blur-md border-b border-zinc-800/50"
>
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 md:h-20">
            <a href="/" class="flex items-center group">
                <img
                    src={logoBlanc.src}
                    alt="Chorus Symphonia"
                    class="h-14 md:h-16 w-auto"
                />
            </a>

            <div class="hidden md:flex items-center flex-1 ml-10">
                <ul class="flex items-center gap-8">
                    {
                        navItems.map((item) => (
                            <li>
                                <a
                                    href={item.href}
                                    class="text-zinc-400 hover:text-purple-400 transition-colors text-sm font-medium uppercase tracking-wider"
                                >
                                    {item.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>

                <div
                    class="ml-auto flex items-center gap-3 pl-7 border-l border-zinc-800/70"
                >
                    {
                        isAuthenticated ? (
                            <>
                                <a
                                    href="/compte"
                                    class="inline-flex items-center justify-center w-11 h-11 rounded-full bg-[#7a6290] hover:bg-[#8c70a4] text-white transition-colors"
                                    aria-label="Mon compte"
                                    title="Mon compte"
                                >
                                    {profilePhotoUrl ? (
                                        <img
                                            src={profilePhotoUrl}
                                            alt="Photo de profil"
                                            class="w-11 h-11 rounded-full object-cover border border-white/25"
                                        />
                                    ) : (
                                        <svg
                                            class="w-5 h-5"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                                            />
                                        </svg>
                                    )}
                                </a>

                                <form method="post" action="/api/auth/logout">
                                    <button
                                        type="submit"
                                        class="inline-flex items-center justify-center px-5 py-2 rounded-full bg-purple-600 hover:bg-purple-500 text-white transition-colors text-sm font-semibold uppercase tracking-wider"
                                    >
                                        Déconnexion
                                    </button>
                                </form>
                            </>
                        ) : (
                            <>
                                {guestItems.map((item) => (
                                    <a
                                        href={item.href}
                                        class={
                                            item.href === "/connexion"
                                                ? "inline-flex items-center justify-center px-5 py-2 rounded-full bg-purple-600 hover:bg-purple-500 text-white transition-colors text-sm font-semibold uppercase tracking-wider"
                                                : "inline-flex items-center justify-center px-5 py-2 rounded-full bg-[#7a6290] hover:bg-[#8c70a4] text-white transition-colors text-sm font-semibold uppercase tracking-wider"
                                        }
                                    >
                                        {item.label}
                                    </a>
                                ))}
                            </>
                        )
                    }
                </div>
            </div>

            <button
                id="mobile-menu-btn"
                class="md:hidden p-2 text-zinc-400 hover:text-purple-400 transition-colors"
                aria-label="Menu"
            >
                <svg
                    class="w-6 h-6"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
        </div>
    </nav>

    <div
        id="mobile-menu"
        class="md:hidden hidden bg-zinc-900/95 backdrop-blur-md border-t border-zinc-800"
    >
        <ul class="px-4 pt-4 pb-3 space-y-2">
            {
                navItems.map((item) => (
                    <li>
                        <a
                            href={item.href}
                            class="block py-3 px-4 text-zinc-400 hover:text-purple-400 hover:bg-zinc-800/50 rounded-lg transition-all text-sm font-medium uppercase tracking-wider"
                        >
                            {item.label}
                        </a>
                    </li>
                ))
            }
        </ul>

        <div class="px-4 pb-4 pt-3 border-t border-zinc-800/80">
            {
                isAuthenticated ? (
                    <div class="space-y-2">
                        <a
                            href="/compte"
                            class="block py-3 px-4 text-center bg-[#7a6290] hover:bg-[#8c70a4] text-white rounded-lg transition-all text-sm font-semibold uppercase tracking-wider"
                        >
                            Mon compte
                        </a>
                        <form method="post" action="/api/auth/logout">
                            <button
                                type="submit"
                                class="w-full py-3 px-4 text-center bg-purple-600 hover:bg-purple-500 text-white rounded-lg transition-all text-sm font-semibold uppercase tracking-wider"
                            >
                                Déconnexion
                            </button>
                        </form>
                    </div>
                ) : (
                    <ul class="space-y-2">
                        {guestItems.map((item) => (
                            <li>
                                <a
                                    href={item.href}
                                    class={
                                        item.href === "/connexion"
                                            ? "block py-3 px-4 text-center bg-purple-600 hover:bg-purple-500 text-white rounded-lg transition-all text-sm font-semibold uppercase tracking-wider"
                                            : "block py-3 px-4 text-center bg-[#7a6290] hover:bg-[#8c70a4] text-white rounded-lg transition-all text-sm font-semibold uppercase tracking-wider"
                                    }
                                >
                                    {item.label}
                                </a>
                            </li>
                        ))}
                    </ul>
                )
            }
        </div>
    </div>
</header>

<script>
    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");

    mobileMenuBtn?.addEventListener("click", () => {
        mobileMenu?.classList.toggle("hidden");
    });
</script>
