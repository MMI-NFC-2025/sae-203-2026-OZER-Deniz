---

---

<section class="py-24 bg-zinc-950 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
            <div class="order-2 lg:order-1">
                <span
                    class="inline-block text-purple-400 font-medium uppercase tracking-wider text-sm mb-4"
                    >Le lieu</span
                >
                <h2
                    class="font-serif text-4xl sm:text-5xl font-bold text-zinc-100 mb-6 text-balance"
                >
                    La Citadelle de Besancon
                </h2>
                <p class="text-zinc-400 leading-relaxed mb-6">
                    Chef-d'oeuvre de Vauban et site classe au patrimoine mondial
                    de l'UNESCO, la Citadelle de Besancon offre un cadre
                    majestueux et une acoustique exceptionnelle pour nos
                    concerts.
                </p>
                <p class="text-zinc-400 leading-relaxed mb-8">
                    Perchee sur un eperon rocheux dominant la vieille ville,
                    elle vous invite a vivre la musique classique dans un
                    environnement historique unique.
                </p>

                <div class="space-y-4">
                    <div class="flex items-start gap-4">
                        <div
                            class="w-10 h-10 rounded-full bg-purple-500/20 flex items-center justify-center shrink-0"
                        >
                            <svg
                                class="w-5 h-5 text-purple-400"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                ></path>
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-zinc-100 font-medium mb-1">
                                Acces facilite
                            </h3>
                            <p class="text-zinc-500 text-sm">
                                Navettes gratuites depuis le centre-ville
                            </p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div
                            class="w-10 h-10 rounded-full bg-purple-500/20 flex items-center justify-center shrink-0"
                        >
                            <svg
                                class="w-5 h-5 text-purple-400"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-zinc-100 font-medium mb-1">
                                Site UNESCO
                            </h3>
                            <p class="text-zinc-500 text-sm">
                                Patrimoine mondial de l'humanite
                            </p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div
                            class="w-10 h-10 rounded-full bg-purple-500/20 flex items-center justify-center shrink-0"
                        >
                            <svg
                                class="w-5 h-5 text-purple-400"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15.536a5 5 0 001.414 1.414m2.828-9.9a9 9 0 0112.728 0"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-zinc-100 font-medium mb-1">
                                Acoustique remarquable
                            </h3>
                            <p class="text-zinc-500 text-sm">
                                Un ecrin parfait pour la musique classique
                            </p>
                        </div>
                    </div>
                </div>

                <a
                    href="/infos-pratiques"
                    class="inline-flex items-center gap-2 mt-8 bg-purple-600 hover:bg-purple-500 text-white font-semibold px-6 py-3 rounded-full transition-all hover:scale-105"
                >
                    Infos pratiques
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                </a>
            </div>

            <div class="order-1 lg:order-2 relative">
                <div class="aspect-square rounded-2xl overflow-hidden">
                    <img
                        src="https://images.unsplash.com/photo-1600002415506-dd06090d3480?auto=format&fit=crop&w=1200&q=80"
                        alt="Citadelle de Besancon"
                        class="w-full h-full object-cover"
                    />
                </div>
                <div
                    class="absolute -bottom-6 -left-6 w-48 h-48 border-2 border-purple-500/30 rounded-2xl -z-10"
                >
                </div>
            </div>
        </div>
    </div>
</section>
