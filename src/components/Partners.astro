---
const partners = [
    { name: "Region Bourgogne-Franche-Comte", type: "Institutionnel" },
    { name: "Ville de Besancon", type: "Institutionnel" },
    { name: "Ministere de la Culture", type: "Institutionnel" },
    { name: "France Musique", type: "Media" },
    { name: "Credit Agricole", type: "Mecene" },
    { name: "EDF", type: "Mecene" },
];
---

<section class="py-24 bg-zinc-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <span
                class="inline-block text-purple-400 font-medium uppercase tracking-wider text-sm mb-4"
                >Partenaires</span
            >
            <h2
                class="font-serif text-4xl sm:text-5xl font-bold text-zinc-100 mb-6"
            >
                Ils nous soutiennent
            </h2>
            <p class="text-zinc-400 max-w-2xl mx-auto">
                Le Festival Chorus Symphonia est rendu possible grace au soutien
                de nos partenaires institutionnels et prives.
            </p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
            {
                partners.map((partner) => (
                    <div class="bg-zinc-800/50 hover:bg-zinc-800 rounded-xl p-6 flex flex-col items-center justify-center text-center transition-all group">
                        <div class="w-16 h-16 rounded-full bg-zinc-700/50 group-hover:bg-purple-500/20 flex items-center justify-center mb-4 transition-all">
                            <svg
                                class="w-8 h-8 text-zinc-400 group-hover:text-purple-400 transition-colors"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="1.5"
                                    d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                                />
                            </svg>
                        </div>
                        <h3 class="text-zinc-200 font-medium text-sm mb-1 group-hover:text-purple-400 transition-colors">
                            {partner.name}
                        </h3>
                        <span class="text-zinc-500 text-xs">
                            {partner.type}
                        </span>
                    </div>
                ))
            }
        </div>

        <div class="mt-16 text-center">
            <div
                class="inline-flex flex-col sm:flex-row items-center gap-4 bg-zinc-800/50 rounded-2xl p-8"
            >
                <div class="text-left">
                    <h3
                        class="font-serif text-xl font-semibold text-zinc-100 mb-2"
                    >
                        Devenez partenaire
                    </h3>
                    <p class="text-zinc-400 text-sm">
                        Rejoignez l'aventure Chorus Symphonia et associez votre
                        image a l'excellence musicale.
                    </p>
                </div>
                <a
                    href="/contact"
                    class="shrink-0 inline-flex items-center gap-2 bg-purple-600 hover:bg-purple-500 text-white font-semibold px-6 py-3 rounded-full transition-all hover:scale-105"
                >
                    Nous contacter
                </a>
            </div>
        </div>
    </div>
</section>
